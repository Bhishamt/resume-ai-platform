# Database
DATABASE_URL=postgresql://user:password@localhost:5432/resume_db

# Security
SECRET_KEY=generate_a_secure_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Redis & Celery
REDIS_URL=redis://localhost:6379/0

# AI Provider (Google Gemini)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Storage (S3 Compatible - AWS / R2)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_BUCKET_NAME=your-resume-bucket-name
AWS_REGION=us-east-1
S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com # Change if using R2/MinIO

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
