# =============================================================================
# AI Resume Analyzer & Job Match Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Project ──────────────────────────────────────────────────────────────────
PROJECT_NAME="AI Resume Analyzer & Job Match Platform"
API_V1_STR=/api/v1
APP_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost/dbname

# For Docker Compose
POSTGRES_USER=resumeai
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=resumeai_prod

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ─── AI Provider ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
MAX_REQUEST_SIZE=20971520

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300
REDIS_DASHBOARD_CACHE_TTL=60
REDIS_SESSION_TTL=86400

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# ─── Email ────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER options: smtp | sendgrid | console
EMAIL_PROVIDER=console
EMAIL_ENABLED=false

# SMTP settings (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@resumeai.com
SMTP_FROM_NAME="AI Resume Analyzer"
SMTP_USE_TLS=true

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ─── Storage ──────────────────────────────────────────────────────────────────
# STORAGE_BACKEND options: local | s3
STORAGE_BACKEND=local

# AWS S3 (used when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1
# For MinIO/LocalStack: AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_ENDPOINT_URL=

# ─── Observability ────────────────────────────────────────────────────────────
ENABLE_METRICS=true
LOG_LEVEL=INFO
LOG_FORMAT=json
# Sentry (optional — leave empty to disable)
SENTRY_DSN=

# ─── Celery Flower (monitoring UI) ────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_in_production
